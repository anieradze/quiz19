<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Change Password</title>
</head>
<body>

<h1>Change Password</h1>

<% if(error) { %>
    <p><%= error %></p>
<% } %>

<% if(success) { %>
    <p><%= success %></p>
<% } %>
<form action="/auth/change-password" method="POST">
    <input
            type="password"
            name="currentPassword"
            placeholder="Current Password"
            required
    >
    <input
            type="password"
            name="newPassword"
            placeholder="New Password"
            required
    >
    <button>Update Password</button>
</form>
</body>
</html>